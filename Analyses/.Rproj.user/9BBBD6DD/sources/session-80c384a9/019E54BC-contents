# Data processing

## Score transformation

NAs in score columns are treated such that models were not able to generate something meaningful. In the context of the TVD-MI score this will be interpreted as a score of 0.

```{r}
paper_llm_score_tfr <- paper_llm_score |> 
  mutate(across(
    contains("score"), 
    ~ replace_na(as.numeric(.), 0)
  )) |> 
  mutate(total_score = (tpr_avg_tvd_mi_score - fpr_avg_tvd_mi_score))

paper_human_score_tfr <- paper_human_score |> 
  mutate(across(
    contains("score"), 
    ~ replace_na(as.numeric(.), 0)
  )) |> 
  mutate(total_score = (tpr_avg_tvd_mi_score - fpr_avg_tvd_mi_score))
```

## Parameter transformation

```{r}
data_cleaned <- paper_llm_score_tfr |> 
  mutate(
    hyperparameter = case_when(
      !is.na(reasoning_effort) ~ paste0("Re ", reasoning_effort),
      !is.na(temperature) ~ paste0("Tempr ", temperature),
      TRUE ~ "default"
    )
  ) |> 
  mutate(
    chain_of_thought = case_match(
      chain_of_thought,
      "Explain your thought process step by step." ~ "True",
      NA ~ "False",
      .default = chain_of_thought
    ),
    scope = case_match(
      scope,
      "full_text" ~ "Full text",
      "abstract"  ~ "Abstract only",
      .default = scope
    )
  )
```

## Bootstraping (preparation)

The setup for non-parametric bootstraping is adopted from[@robertsonLetsMeasureInformation2025].

```{r}
# Create configuration label
data_bootstraped <- data_cleaned |> 
  unite("config", model, hyperparameter, chain_of_thought, scope,
        sep = "_", remove = FALSE) |>
  mutate(config_label = paste0("Config_", as.numeric(factor(config))))

# Create bootstrap matrix
bootstrap_matrix <- data_bootstraped |> 
  select(paper_id, config_label, total_score) |> 
  pivot_wider(names_from = config_label,
              values_from = total_score) |> 
  column_to_rownames("paper_id") |> 
  as.matrix()

# Store configuration keys
config_lookup <- data_bootstraped|> 
  distinct(config_label, model, hyperparameter, chain_of_thought, scope) |> 
  arrange(config_label)

# Parameters for bootstraping
num_iterations <- NUM_ITERATIONS
alpha <- (1 - CONFIDENCE_LVL) / 2
lower_percentile <- alpha
upper_percentile <- (1 - alpha)
n_papers <- nrow(bootstrap_matrix)
n_configs <- ncol(bootstrap_matrix)

# Create empty placeholder matrix
boot_results <- matrix(NA, nrow = num_iterations, ncol = n_configs)
colnames(boot_results) <- colnames(bootstrap_matrix)
```

## Bootstrapping (execution)

Bootstrapping yields confidence intervals (CIs) around the average TVD-MI scores per configuration.

```{r}
set.seed(42)

# Run bootstrap
for (i in 1:num_iterations) {
  resample_idx <- sample(1:n_papers, size = n_papers, replace = TRUE)
  boot_results[i, ] <- colMeans(bootstrap_matrix[resample_idx, , drop = FALSE])
}

# Bind statistics
summary_stats <- data.frame(
  config_label = colnames(bootstrap_matrix),
  mean_tvd_mi  = colMeans(bootstrap_matrix), # The original observed mean
  ci_lower     = apply(boot_results, 2, quantile, probs = lower_percentile),
  ci_upper     = apply(boot_results, 2, quantile, probs = upper_percentile)
)

# Join with configuration keys
bootstrap_report <- summary_stats |> 
  left_join(config_lookup, by = "config_label") |> 
  arrange(desc(mean_tvd_mi))

```

## Bootstrapping for the paper / human-authored review scores

```{r}
scores <- paper_human_score_tfr$total_score
num_iterations <- 10000

boot_means <- replicate(num_iterations, {
sample_scores <- sample(scores, length(scores), replace = TRUE)
mean(sample_scores, na.rm = TRUE)
})

boot_quantile <- quantile(boot_means, probs = c(0.025, 0.975))

data_prepared <- paper_human_score_tfr |> 
  mutate(
    overall_mean = mean(!!sym("total_score"), na.rm = TRUE),
    ci_lower = boot_quantile[1],
    ci_upper = boot_quantile[2]
  )
```

