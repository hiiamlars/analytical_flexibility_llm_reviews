plot_paper_human_spec_curve <- function(df, score_col = "total_score") {

  plot_data <- df |>
    select(paper_id, !!sym(score_col), overall_mean, ci_lower, ci_upper) |> 
    rename(score = !!sym(score_col)) |>
    arrange(score) |>
    mutate(rank = row_number()) |>
    mutate(paper_id = factor(paper_id, levels = paper_id))

  p_top <- ggplot(plot_data, aes(x = rank, y = score)) +
    geom_ribbon(aes(ymin = ci_lower, ymax = ci_upper), 
                fill = "grey80", alpha = 0.4) +
    geom_hline(aes(yintercept = overall_mean), 
               color = "red", linetype = "dashed", size = 0.8) +
    geom_line(color = "grey60", alpha = 0.5) +
    geom_point(color = "#2c3e50", size = 1.5) +
    theme_minimal() +
    labs(
      title = "Paper-Level Specification Curve",
      subtitle = paste("Points: individual papers | Red line: Mean | Shaded: 95% CI for", score_col),
      y = "Score",
      x = "Ranked Papers"
    ) +
    theme(
      axis.text.x = element_blank(),
      axis.ticks.x = element_blank(),
      panel.grid.minor = element_blank(),
      legend.position = "none"
    )
  
  return(p_top)
}
