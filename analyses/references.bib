@article{chenManagerAIWalk2025,
  title = {A {{Manager}} and an {{AI Walk}} into a {{Bar}}: {{Does ChatGPT Make Biased Decisions Like We Do}}?},
  shorttitle = {A {{Manager}} and an {{AI Walk}} into a {{Bar}}},
  author = {Chen, Yang and Kirshner, Samuel N. and Ovchinnikov, Anton and Andiappan, Meena and Jenkin, Tracy},
  year = 2025,
  month = mar,
  journal = {Manufacturing \& Service Operations Management},
