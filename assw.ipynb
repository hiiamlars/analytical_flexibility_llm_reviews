    {
      "cell_type": "code",
      "source": [
        "# @title Human review standardisation\n",
        "\n",
        "# initialize the client\n",
        "client = LLMClient(simulate=SIMULATE)\n",
        "\n",
        "# iterate over all human reviews\n",
        "for i, col_name in enumerate(HUMAN_REVIEW_COLUMNS):\n",
        "\n",
        "    # store respective column index\n",
        "    review_number = col_name.replace('human_review', '')\n",
        "\n",
        "    # create respective result path\n",
        "    current_results_path = os.path.join(RESULTS_DIR, f\"std_human_revw_{review_number}_res.csv\")\n",
        "\n",
        "    # create respective log path\n",
        "    current_log_path = os.path.join(LOG_DIR, f\"std_human_revw_{review_number}_log.csv\")\n",
        "\n",
        "    # create new result file with hardcoded columns\n",
        "    if not os.path.exists(current_results_path):\n",
        "        with open(current_results_path, 'w', newline='') as f:\n",
        "            writer = csv.writer(f)\n",
        "            writer.writerow(BASE_STAND_REVW_COLMNS)\n",
        "\n",
        "    # create new log file with hardcoded columns\n",
        "    if not os.path.exists(current_log_path):\n",
        "        with open(current_log_path, 'w', newline='') as f:\n",
        "            writer = csv.writer(f)\n",
        "            writer.writerow(BASE_LOG_COLUMNS)\n",
        "\n",
        "    # group by paper_id (to log each paper after the other)\n",
        "    grouped_human_papers = df_human_reviews.groupby('paper_id')\n",
        "\n",
        "    # across all paper_id-groups\n",
        "    for paper_id, paper_group_df in grouped_human_papers:\n",
        "        process_review_source(\n",
        "            df=paper_group_df, # single paper\n",
        "            review_col_name=col_name, # as defined by above iteration\n",
        "            config_model=\"human\", # plaeholder for human reviews\n",
        "            config_temperature=None, # plaeholder for human reviews\n",
        "            config_reasoning_effort=None, # plaeholder for human reviews\n",
        "            config_chain_of_thought=None, # plaeholder for human reviews\n",
        "            results_path=current_results_path, # result path\n",
        "            log_path=current_log_path # log path\n",
